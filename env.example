# Copia este archivo como ".env" y completa tus datos reales.
# NUNCA subas el archivo ".env" a un repositorio público.

# Tu API Key de Resend (la obtienes en https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Correo remitente verificado en Resend
FROM_EMAIL=Only Love <verificacion@tu-dominio.com>

# Frase secreta para firmar las cookies de sesión.
# Usa algo largo y aleatorio, ej: genera una en https://generate-secret.vercel.app/32
SESSION_SECRET=cambia-esto-por-algo-largo-y-aleatorio

# Puerto donde correrá el backend (Render lo asigna automáticamente, no hace falta tocarlo ahí)
PORT=3000

# "production" cuando esté desplegado en Render (activa cookies seguras)
NODE_ENV=production
